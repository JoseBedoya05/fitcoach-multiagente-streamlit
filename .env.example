# Copia este archivo como .env y completa tus claves.
OPENAI_API_KEY=

# Modelos
LLM_MODEL=gpt-4o
LLM_MODEL_FAST=gpt-4o-mini
EMBED_MODEL=intfloat/multilingual-e5-small

# Runtime
# false = dispatcher local compatible con tools MCP, recomendado en Streamlit Cloud
# true  = invoca src/mcp_server_gym.py por stdio usando MCP
USE_MCP_SERVER=true

# RAG
ENABLE_RAG=true
